// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the signed-in user the owner of this doc?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the signed-in user an admin?
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Validate a string field exists and has valid length
    function validString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    // ── pendingSignups (OTP store) ──────────────────────────────────────────
    // Only the server (via Firebase Admin SDK) or an anonymous client
    // creating their own pending record can write here.
    // Nobody can read another user's pending record.
    match /pendingSignups/{email} {
      // Allow unauthenticated write (needed to store OTP before account exists)
      // We lock it down by: rate-limiting happens in app logic + doc TTL
      allow read:   if false;                   // nobody reads this directly
      allow create: if
        request.resource.data.keys().hasAll([
          'hashedOTP','sentAt','expiresAt','attempts',
          'firstName','lastName','phone','displayName'
        ]) &&
        request.resource.data.attempts == 0 &&
        request.resource.data.hashedOTP is string &&
        request.resource.data.hashedOTP.size() == 64 &&  // SHA-256 hex = 64 chars
        request.resource.data.sentAt  is int &&
        request.resource.data.expiresAt is int &&
        // expiresAt must be sentAt + 5min (±5s tolerance)
        (request.resource.data.expiresAt - request.resource.data.sentAt) >= 295000 &&
        (request.resource.data.expiresAt - request.resource.data.sentAt) <= 305000;

      allow update: if
        // Only allow incrementing attempts counter or replacing with new OTP
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['attempts','hashedOTP','sentAt','expiresAt']) &&
        (
          // increment attempts
          (request.resource.data.attempts == resource.data.attempts + 1 &&
           request.resource.data.attempts <= 5) ||
          // resend: reset with new OTP
          (request.resource.data.attempts == 0)
        );

      allow delete: if true;  // cleanup after verification
    }

    // ── users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Read: only the owner or an admin
      allow get:  if isOwner(uid) || isAdmin();
      allow list: if isAdmin();

      // Create: only by the authenticated owner (right after signup)
      allow create: if
        isOwner(uid) &&
        request.resource.data.uid == request.auth.uid &&
        validString(request.resource.data.email, 5, 254) &&
        validString(request.resource.data.firstName, 2, 50) &&
        validString(request.resource.data.lastName, 2, 50) &&
        request.resource.data.role == "member" &&       // can't self-assign admin
        request.resource.data.keys().hasAll([
          'uid','email','firstName','lastName','displayName',
          'phone','role','provider','emailVerified','createdAt','updatedAt'
        ]);

      // Update: owner can update profile fields (NOT role, NOT uid, NOT email)
      allow update: if
        isOwner(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid','email','role','createdAt']) &&
        request.resource.data.uid   == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role  == resource.data.role;

      // Admins can update any field including role
      allow update: if isAdmin();

      // Nobody deletes users directly — only via Firebase console
      allow delete: if false;
    }

    // ── sermons ─────────────────────────────────────────────────────────────
    match /sermons/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── events ──────────────────────────────────────────────────────────────
    match /events/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── prayerRequests ──────────────────────────────────────────────────────
    match /prayerRequests/{id} {
      // Members read only their own; admins read all
      allow read:   if isOwner(resource.data.uid) || isAdmin();
      // Members create only for themselves
      allow create: if
        isAuth() &&
        request.resource.data.uid == request.auth.uid &&
        validString(request.resource.data.request, 10, 2000);
      allow update, delete: if isAdmin();
    }

    // ── quizzes ─────────────────────────────────────────────────────────────
    match /quizzes/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── quizResults ─────────────────────────────────────────────────────────
    match /quizResults/{id} {
      allow read:   if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── notifications ────────────────────────────────────────────────────────
    match /notifications/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ── contactMessages ──────────────────────────────────────────────────────
    match /contactMessages/{id} {
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
